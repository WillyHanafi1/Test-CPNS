# Supabase Configuration Template

# Database Connection (PostgreSQL)
# Format: postgresql+asyncpg://postgres:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.upykjfjmfpwegqrbgeoa.supabase.co:5432/postgres

# Redis Connection (Optional for local dev, used for cache/leaderboard)
REDIS_URL=redis://localhost:6379/0

# JWT Secret Key (Generate with: openssl rand -hex 32)
SECRET_KEY=yoursecretkeyhere
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Origins — comma-separated, add your production domain
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.com

# Cookie Security — set to True when running behind HTTPS in production
COOKIE_SECURE=false
